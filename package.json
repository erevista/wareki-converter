{
  "name": "wareki-converter",
  "version": "0.2.0",
  "description": "Zero-dependency, ultra-lightweight Japanese era (wareki) ↔ Western calendar converter",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "size": "tsup && ls -la dist/index.js"
  },
  "keywords": [
    "wareki",
    "japanese",
    "era",
    "calendar",
    "reiwa",
    "heisei",
    "date",
    "converter"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erevista/wareki-converter"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
